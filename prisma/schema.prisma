generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String    @unique
  passwordHash  String?
  handle        String?   @unique
  bio           String?

  isVerified    Boolean   @default(false)
  region        String?
  walletAddress String?

  wins          Int       @default(0)
  losses        Int       @default(0)
  totalEarnings Float     @default(0)
  bankBalance   Float     @default(0)

  isAnonymous        Boolean   @default(false)
  anonHandle         String?   @unique
  dateOfBirth        DateTime?

  resetToken         String?
  resetTokenExpiry   DateTime?

  emailVerifyToken   String?
  emailVerifyExpiry  DateTime?
  interests          String    @default("[]")

  challengesCreated  Beef[]      @relation("Challenger")
  challengesAccepted Beef[]      @relation("Responder")
  messages           Message[]
  offers             BeefOffer[]
  following          Follow[]    @relation("Follower")
  followers          Follow[]    @relation("Following")
  threadImports      ThreadImport[]
  forumThreads       ForumThread[]
  forumComments      ForumComment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Beef {
  id            String    @id @default(cuid())

  claim         String
  categories    String    @default("[]")

  challengerId       String
  challenger         User      @relation("Challenger", fields: [challengerId], references: [id])
  responderId        String?
  responder          User?     @relation("Responder", fields: [responderId], references: [id])

  ante          Float
  totalPot      Float

  startedAt     DateTime?
  endsAt        DateTime?

  status        String    @default("OPEN") // OPEN, LIVE, JUDGING, COMPLETED

  challengerIsAnon Boolean @default(false)
  responderIsAnon  Boolean @default(false)

  winnerId      String?
  judgeId       String?
  judgeName     String?
  judgeDecision String?

  viewCount     Int       @default(0)

  messages      Message[]
  offers        BeefOffer[]
  threadImport  ThreadImport?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BeefOffer {
  id        String   @id @default(cuid())
  beefId    String
  beef      Beef     @relation(fields: [beefId], references: [id], onDelete: Cascade)
  fromId    String
  from      User     @relation(fields: [fromId], references: [id])
  type      String   // RAISE | CLOSE
  amount    Float    @default(0)
  status    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())

  beefId    String
  beef      Beef     @relation(fields: [beefId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  content   String

  createdAt DateTime @default(now())
}

model Follow {
  id            String    @id @default(cuid())

  followerId    String
  follower      User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId   String
  following     User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@unique([followerId, followingId])
}

model ThreadImport {
  id            String    @id @default(cuid())

  beefId        String    @unique
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  platform      String
  sourceUrl     String
  threadData    String
  participants  String

  createdAt     DateTime  @default(now())
}

model ForumThread {
  id        String         @id @default(cuid())
  title     String
  body      String
  authorId  String
  author    User           @relation(fields: [authorId], references: [id])
  comments  ForumComment[]
  textColor String?
  fontStyle String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ForumComment {
  id        String       @id @default(cuid())
  threadId  String
  thread    ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  content   String
  parentId  String?
  textColor String?
  fontStyle String?
  createdAt DateTime     @default(now())
}

model Transaction {
  id            String    @id @default(cuid())

  userId        String
  type          String    // DEPOSIT, WITHDRAWAL, ANTE, PAYOUT, REFUND
  amount        Float
  status        String    // PENDING, COMPLETED, FAILED

  relatedBeefId String?

  paymentProvider String?
  paymentId       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
