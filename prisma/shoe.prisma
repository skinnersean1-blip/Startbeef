generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/shoe-client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String  @id @default(cuid())
  email        String? @unique
  username     String  @unique
  passwordHash String?
  handle       String? @unique
  credits      Int     @default(0)

  shoePosts           ShoePost[]
  shoeOffersMade      ShoeOffer[]          @relation("ShoeOffersMade")
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShoePost {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id])

  listingKind String
  listingType String

  title       String
  brand       String?
  size        String
  condition   String
  description String?
  askingPrice Float?

  status String @default("ACTIVE")

  offers ShoeOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShoeOffer {
  id String @id @default(cuid())

  postId String
  post   ShoePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  offerUserId String
  offerUser   User   @relation("ShoeOffersMade", fields: [offerUserId], references: [id])

  type        String
  offerPostId String?
  offerPrice  Float?
  message     String?

  status String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
